# ═══════════════════════════════════════════════════════════════
#  Travyn Backend — Local MySQL
#  Copy this to application-local.properties and fill in your secrets
# ═══════════════════════════════════════════════════════════════

# ── Datasource ──
spring.datasource.url=jdbc:mysql://localhost:3306/travyn_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=YOUR_MYSQL_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ── JPA / Hibernate ──
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# ── Liquibase (disabled for local — uses ddl-auto) ──
spring.liquibase.enabled=false
